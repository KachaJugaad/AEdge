  },
  "dependencies": {
    "@anomedge/bus": "workspace:*",
    "@anomedge/contracts": "workspace:*",
    "@anomedge/core": "workspace:*",
    "chalk": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
