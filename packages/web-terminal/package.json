{
  "name": "@anomedge/web-terminal",
  "version": "1.0.0",
  "scripts": {
    "build": "vite build",
    "start": "ts-node src/cli.ts",
    "dev": "vite",
    "demo": "ts-node -r tsconfig-paths/register src/demo.ts",
    "server": "ts-node -r tsconfig-paths/register src/server.ts",
