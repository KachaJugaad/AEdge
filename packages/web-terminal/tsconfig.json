{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@anomedge/contracts": ["../contracts/src"],
      "@anomedge/bus": ["../bus/src"],
      "@anomedge/core": ["../core/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
