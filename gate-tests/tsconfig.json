{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@anomedge/bus":       ["../packages/bus/src"],
      "@anomedge/contracts": ["../packages/contracts/src"]
    }
  },
  "include": ["./*.ts"]
}
